        </mxCell>
        <mxCell id="subtitle" value="上部の迂回線はプロジェクト×タスクの列をまたぐ外部キー関係（task_comments/task_files/notifications → users）。project_membersはUNIQUE(project_id, user_id)が複合キー（本システム最重要インデックス、E011の実体）。notifications.task_idはON DELETE SET NULL（タスク削除後も通知は残る、REL-011）。" style="text;html=1;fontSize=11;fontColor=#666666;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1100" height="40" as="geometry"/>
        </mxCell>
