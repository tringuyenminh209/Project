<mxfile host="claude-code">
    <diagram id="hr-attendance-er" name="ER図">
        <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1480" pageHeight="1224" math="0" shadow="0">
