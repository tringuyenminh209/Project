        <mxCell id="title" value="HR &amp; Attendance System ER図（7テーブル / 7リレーション）" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1a3a5c;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="大分類: マスタ / トラン / サポート（ログ）。leave_requestsはemployeesへ2本のFK（申請者=employee_id / 承認者=approved_by）を持つ。" style="text;html=1;fontSize=11;fontColor=#666666;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1000" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle2" value="全リレーションが隣接列間のforward-edge（列をまたぐ関係なし）— bypass laneは不要。employees.idは4リレーションの親のため「1」ラベルを縦に分散配置。" style="text;html=1;fontSize=11;fontColor=#666666;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="82" width="1000" height="24" as="geometry"/>
        </mxCell>
